:root {
  --bg: #ffffff;
  --text: #1f2933;
  --muted: #6b7280;
  --line: #e5e7eb;
  --accent: #2f6f95;
  --accent-soft: rgba(47, 111, 149, 0.08);
  --sidebar: 285px;
  --max-width: 1140px;
  --radius: 18px;
}

html[data-theme="dark"] {
  --bg: #0f141b;
  --text: #eef3f8;
  --muted: #9aa6b2;
  --line: #273241;
  --accent: #8dcbef;
  --accent-soft: rgba(141, 203, 239, 0.1);
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  line-height: 1.72;
  transition: background 0.2s ease, color 0.2s ease;
}

a {
  color: var(--accent);
  text-decoration: none;
}

a:hover { text-decoration: underline; }

.container {
  width: min(calc(100% - 40px), var(--max-width));
  margin: 0 auto;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 30;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--bg) 95%, transparent);
  backdrop-filter: blur(10px);
}

.topbar-inner {
  min-height: 66px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.site-title {
  font-size: 1.03rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}

.nav-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

nav {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
}

.nav-link,
.nav-anchor {
  border: 0;
  background: transparent;
  color: var(--text);
  font: inherit;
  font-size: 0.98rem;
  padding: 8px 10px;
  cursor: pointer;
  border-radius: 8px;
}

.nav-link:hover,
.nav-anchor:hover {
  background: var(--accent-soft);
  text-decoration: none;
}

.nav-link.active,
.nav-anchor.active {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 4px;
  background: transparent;
}

.theme-toggle {
  border: 1px solid var(--line);
  background: transparent;
  color: var(--text);
  border-radius: 999px;
  padding: 7px 12px;
  font: inherit;
  font-size: 0.92rem;
  cursor: pointer;
}

.page-shell {
  padding: 30px 0 42px;
}

.layout {
  display: grid;
  grid-template-columns: var(--sidebar) minmax(0, 1fr);
  gap: 48px;
  align-items: start;
}

.sidebar {
  position: sticky;
  top: 96px;
}

.portrait-frame {
  width: 180px;
  max-width: 100%;
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--line);
  background: color-mix(in srgb, var(--accent) 7%, var(--bg));
  margin-bottom: 18px;
}

.avatar {
  width: 100%;
  aspect-ratio: 4 / 5;
  object-fit: cover;
  object-position: center 18%;
  display: block;
}

.sidebar h1 {
  margin: 0;
  font-size: 1.72rem;
  line-height: 1.14;
}

.role {
  margin: 7px 0 18px;
  color: var(--muted);
  font-size: 1rem;
}

.sidebar-list,
.sidebar-links {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 10px;
  font-size: 0.98rem;
}

.sidebar-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  color: var(--muted);
}

.icon {
  flex: 0 0 18px;
  text-align: center;
  color: var(--accent);
  font-size: 0.95rem;
  line-height: 1.4;
  margin-top: 1px;
}

.sidebar-links {
  margin-top: 18px;
  padding-top: 18px;
  border-top: 1px solid var(--line);
}

.content {
  min-width: 0;
}

.intro {
  margin-bottom: 26px;
}

.page h2 {
  margin: 0 0 14px;
  font-size: 2.22rem;
  line-height: 1.14;
  font-weight: 700;
  letter-spacing: -0.01em;
}

.intro p,
.section p,
.entry p,
.muted,
li {
  font-size: 1.02rem;
}

.intro p,
.section p,
.muted {
  color: color-mix(in srgb, var(--text) 84%, var(--muted));
}

.section {
  padding-top: 22px;
  border-top: 1px solid var(--line);
  margin-top: 22px;
}

.section:first-child {
  border-top: 0;
  padding-top: 0;
  margin-top: 0;
}

.section h3 {
  margin: 0 0 12px;
  font-size: 1.34rem;
  line-height: 1.25;
  display: flex;
  align-items: center;
  gap: 9px;
}

.section h3 .heading-icon {
  font-size: 1rem;
  color: var(--accent);
}

.entry {
  padding: 14px 0;
  border-top: 1px solid var(--line);
}

.entry:first-child {
  border-top: 0;
  padding-top: 0;
}

.entry-title {
  font-size: 1.08rem;
  font-weight: 700;
  line-height: 1.42;
  margin-bottom: 3px;
}

.course-link {
  font-weight: 700;
}

.course-link::after,
.paper-link::after {
  content: " ↗";
  font-weight: 400;
}

.simple-list {
  margin: 0;
  padding-left: 20px;
  display: grid;
  gap: 10px;
}

.footer {
  border-top: 1px solid var(--line);
  color: var(--muted);
  font-size: 0.92rem;
  padding: 18px 0 28px;
}

@media (max-width: 900px) {
  .layout {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .sidebar {
    position: static;
  }

  .portrait-frame {
    width: 170px;
  }
}

@media (max-width: 720px) {
  .topbar-inner {
    flex-direction: column;
    align-items: flex-start;
    padding: 12px 0;
  }

  .nav-wrap {
    width: 100%;
    justify-content: space-between;
  }

  .page h2 {
    font-size: 1.82rem;
  }
}